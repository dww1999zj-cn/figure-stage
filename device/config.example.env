# 复制为 device/config.env（勿提交 git）
# 也可用门户 http://<设备IP>:8080/credentials 填写

DEVICE_ID=
# 由运营方提供，须与云端 CLOUD_API_TOKEN 完全一致（门户「凭证」页填写）
DEVICE_CLOUD_TOKEN=
CLOUD_BASE_URL=https://figure-stage-cloud.zeabur.app

DOUBAO_APP_ID=
DOUBAO_ACCESS_KEY=
DOUBAO_APP_KEY=
DOUBAO_RESOURCE_ID=volc.speech.dialog
DOUBAO_WS_URL=wss://openspeech.bytedance.com/api/v3/realtime/dialogue

AUDIO_DEVICE_ID=0
SESSION_IDLE_SECONDS=60
# 兼容旧配置名（等同 SESSION_IDLE_SECONDS）
IDLE_TIMEOUT_SECONDS=60

# 名字唤醒：聊完后手办不移开时喊名称再开聊（已取消 60s 视觉自动再开）
FS_NAME_WAKE=true
# WAKE_MAX_RECORD_SEC=3.5
# WAKE_SPEECH_RMS=450
# WAKE_SILENCE_RMS=280
# WAKE_COOLDOWN_SEC=3

# 舞台：空台 baseline 与启动扫描（注册后首次启动默认多等 10s）
# FS_BASELINE_WAIT_SEC=10
FS_STARTUP_SCAN=true

LUCKIN_ENABLED=false
LUCKIN_TOKEN=
LUCKIN_LONGITUDE=
LUCKIN_LATITUDE=

# 监督进程（python -m supervisor，见 install.sh / systemd）
FS_WIFI_WAIT_SEC=20
FS_SUPERVISOR_POLL_SEC=2
FS_AUTO_STAGE=true
FS_PORTAL_HOST=0.0.0.0
FS_PORTAL_PORT=8080
# mDNS 门户地址 http://<hostname>.local:8080/
FS_DEVICE_HOSTNAME=figure-stage
# FS_SHOW_PREVIEW=true   # 调试时在桌面/VNC 下开 OpenCV 预览（默认关）
# FS_PROMPT_COOLDOWN_SEC=45
# FS_WIFI_IFACE=wlan0
# FS_HOTSPOT_SSID=FigureStage-Setup
# FS_HOTSPOT_PASSWORD=figurestage
