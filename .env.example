# 复制为 .env 后填写，勿提交 git

DOUBAO_APP_ID=
DOUBAO_ACCESS_KEY=
DOUBAO_APP_KEY=

# 可选
DOUBAO_RESOURCE_ID=volc.speech.dialog
DOUBAO_WS_URL=wss://openspeech.bytedance.com/api/v3/realtime/dialogue
DOUBAO_MODEL=1.2.1.1

# DINOv2 特征注册与 stage_feature.py 匹配（纯本地识别，无需 ARK_API_KEY）
FEATURE_MODEL_PATH=/home/pi/Desktop/dinov2_vits14.onnx
FEATURE_REGISTRY_DIR=registry
FEATURE_MIN_SCORE=0.60
FEATURE_MIN_MARGIN=0.10
FEATURE_ROI_FRACTION=0.6
FEATURE_REGISTER_FRAMES=24
FEATURE_REGISTER_COUNTDOWN=3
FEATURE_MIN_INTERVAL_SEC=1.0
FEATURE_TRIGGER_DIFF_ON=18
FEATURE_TRIGGER_DIFF_OFF=10
FEATURE_BASELINE_FRAMES=30
FEATURE_STABLE_FRAMES=8

AUDIO_DEVICE_ID=0
IDLE_TIMEOUT_SECONDS=60
SWITCH_COOLDOWN_SECONDS=5

# 豆包 Realtime 内置联网（stage_feature.py 读取；默认 false）
DOUBAO_ENABLE_WEBSEARCH=false
DOUBAO_WEBSEARCH_TYPE=web_agent
DOUBAO_WEBSEARCH_API_KEY=
DOUBAO_WEBSEARCH_BOT_ID=
DOUBAO_WEBSEARCH_RESULT_COUNT=5
DOUBAO_WEBSEARCH_NO_RESULT_MESSAGE=
# DOUBAO_LOCATION_CITY=上海
# DOUBAO_LOCATION_PROVINCE=上海
# DOUBAO_LOCATION_COUNTRY_CODE=CN
